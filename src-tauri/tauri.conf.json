{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DuanDB",
  "version": "0.4.1",
  "identifier": "com.duandb.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "pnpm dev:hot",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "title": "DuanDB",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/duanzhichaomy/duanDB/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhERTY2N0YwOEI5MkU5REEKUldUYTZaS0w4R2ZtamFuVVVRZ0pqT3hDWFM3WXAxRUg3WHZMczJZRlpoQ0w2bG8yN1FRUFZlQkYK"
    }
  }
}
